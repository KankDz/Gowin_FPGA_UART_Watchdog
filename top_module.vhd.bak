library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;

entity top_module is
    Port (
        clk   : in  std_logic;
	--rst : in std_logic;

        -- RX
        rx_i  : in  std_logic;

        -- TX
        tx_o  : out std_logic;

        -- BUS t? uart_engine ??a ra ngo‡i
        wr_en : out std_logic;
        rd_en : out std_logic;
        addr  : out std_logic_vector(7 downto 0);
        wdata : out std_logic_vector(31 downto 0);
        rdata : in  std_logic_vector(31 downto 0)
    );
end top_module;

architecture rtl of top_module is

    component uart_tx_rx is
        Port (
            clk         : in  std_logic;
            rx_i        : in  std_logic;
            tx_o        : out std_logic;

            -- RX FIFO
            read_rx     : in  std_logic;
            empty_rx    : out std_logic;
            ffrx_data_o : out std_logic_vector(7 downto 0);

            -- TX FIFO
            tx_w_data_i : in  std_logic_vector(7 downto 0);
            write_tx    : in  std_logic;
            tx_full     : out std_logic
        );
    end component;

    component uart_engine is
        port (
            clk     : in  std_logic;
            rst     : in  std_logic;

            -- RX FIFO
            empty_o : in  std_logic;
            rdata_o : in  std_logic_vector(7 downto 0);
            rd_i    : out std_logic;

            -- TX FIFO
            full_o  : in  std_logic;
            wdata_i : out std_logic_vector(7 downto 0);
            wd_i    : out std_logic;

            -- BUS
            wr_en   : out std_logic;
            rd_en   : out std_logic;
            addr    : out std_logic_vector(7 downto 0);
            wdata   : out std_logic_vector(31 downto 0);
            rdata   : in  std_logic_vector(31 downto 0)
        );
    end component;

    -- ===============================
    -- Signal n?i gi?a 2 module
    -- ===============================

    -- T? uart_engine sang RX FIFO
    signal read_rx_s     : std_logic;

    -- T? RX FIFO sang uart_engine
    signal empty_rx_s    : std_logic;
    signal rx_data_s     : std_logic_vector(7 downto 0);

    -- T? uart_engine sang TX FIFO
    signal tx_data_s     : std_logic_vector(7 downto 0);
    signal write_tx_s    : std_logic;

    -- T? TX FIFO sang uart_engine
    signal tx_full_s     : std_logic;

begin

    -- ===============================
    -- Module UART TX/RX
    -- ===============================
    u_uart_tx_rx : uart_tx_rx
        port map (
            clk         => clk,
            rx_i        => rx_i,
            tx_o        => tx_o,

            -- RX FIFO
            read_rx     => read_rx_s,
            empty_rx    => empty_rx_s,
            ffrx_data_o => rx_data_s,

            -- TX FIFO
            tx_w_data_i => tx_data_s,
            write_tx    => write_tx_s,
            tx_full     => tx_full_s
        );

    -- ===============================
    -- Module UART Engine
    -- ===============================
    u_uart_engine : uart_engine
        port map (
            clk     => clk,
            rst     => rst,

            -- RX FIFO
            empty_o => empty_rx_s,
            rdata_o => rx_data_s,
            rd_i    => read_rx_s,

            -- TX FIFO
            full_o  => tx_full_s,
            wdata_i => tx_data_s,
            wd_i    => write_tx_s,

            -- BUS
            wr_en   => wr_en,
            rd_en   => rd_en,
            addr    => addr,
            wdata   => wdata,
            rdata   => rdata
        );

end rtl;
